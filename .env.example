# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
# Vercel Postgres, Neon, Supabase, Railway, etc. all work.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Clerk Auth (optional — app runs without auth when omitted) ────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Frontend Clerk key (prefixed with VITE_ so Vite exposes it to the browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Session ───────────────────────────────────────────────────────────────────
# Required. Random string used to sign sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-secret-here

# ── Ads (optional) ────────────────────────────────────────────────────────────
# Google AdSense publisher ID. Leave blank to disable ad slots.
VITE_ADSENSE_PUBLISHER_ID=
