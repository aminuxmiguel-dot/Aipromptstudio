{
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/ai-prompt-studio run build",
  "outputDirectory": "artifacts/ai-prompt-studio/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "BASE_PATH": "/"
  }
}
